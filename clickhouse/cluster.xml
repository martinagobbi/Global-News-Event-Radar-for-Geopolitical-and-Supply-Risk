<clickhouse>
    <!--
        Cluster topology: 2 shards × 3 replicas (6 server nodes).

        Both wide-column tables are sharded by cityHash64(GLOBALEVENTID); within
        a shard, all THREE replicas hold identical copies (ReplicatedMergeTree),
        so a shard survives losing up to two of its nodes without data loss.

        internal_replication=true: an INSERT into the Distributed table is sent
        to ONE replica per shard, and ReplicatedMergeTree copies it to the other
        two replicas via Keeper. (With false, the Distributed table would write
        to every replica itself and triple-insert — wrong for replicated tables.)

        Shard 1 = clickhouse-s1r1 + clickhouse-s1r2 + clickhouse-s1r3
        Shard 2 = clickhouse-s2r1 + clickhouse-s2r2 + clickhouse-s2r3
    -->
    <remote_servers>
        <gnews_cluster>
            <shard>
                <internal_replication>true</internal_replication>
                <replica><host>clickhouse-s1r1</host><port>9000</port></replica>
                <replica><host>clickhouse-s1r2</host><port>9000</port></replica>
                <replica><host>clickhouse-s1r3</host><port>9000</port></replica>
            </shard>
            <shard>
                <internal_replication>true</internal_replication>
                <replica><host>clickhouse-s2r1</host><port>9000</port></replica>
                <replica><host>clickhouse-s2r2</host><port>9000</port></replica>
                <replica><host>clickhouse-s2r3</host><port>9000</port></replica>
            </shard>
        </gnews_cluster>
    </remote_servers>

    <!-- 3-node Keeper ensemble: coordinates ON CLUSTER DDL and table replication. -->
    <zookeeper>
        <node><host>clickhouse-keeper-1</host><port>9181</port></node>
        <node><host>clickhouse-keeper-2</host><port>9181</port></node>
        <node><host>clickhouse-keeper-3</host><port>9181</port></node>
    </zookeeper>
</clickhouse>
